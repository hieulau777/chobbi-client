# NextAuth - required
AUTH_SECRET=generate-with-npx-auth-secret

# Google OAuth
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Java backend URL (used by next.config rewrites & images)
# In dev, backend usually runs at http://localhost:9090
BACKEND_URL=http://localhost:9090

# WebSocket for real-time notifications (SockJS endpoint on backend)
NEXT_PUBLIC_WS_URL=http://localhost:9090/ws

# Seller app URL (used for "Bán hàng cùng Chobbi" CTAs)
# In dev, seller app usually runs at http://localhost:3001
NEXT_PUBLIC_SELLER_URL=http://localhost:3001
